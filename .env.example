# =============================================================================
# Qdrant Vector Database
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=qwepoi123098
QDRANT_COLLECTION=documents

# =============================================================================
# MinIO  — Object storage for original uploaded documents
# =============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=qwepoi123098
MINIO_BUCKET=documents
MINIO_SECURE=false

# =============================================================================
# Docling  — Document extraction (PDF, DOCX, PPTX, XLSX, …)
# =============================================================================
DOCLING_URL=http://localhost:5001/ui
DOCLING_MAX_WORKERS=4 # docker-compose only

# =============================================================================
# LLM  — OpenAI-compatible endpoint (shared base URL + API key)
# =============================================================================
OPENAI_URL=http://localhost:11434/v1
OPENAI_API_KEY=whatever
# Final answer generation, HyDE, RAGAS — reasoning / quality
LLM_MODEL=qwen3:14b
LLM_TIMEOUT=120
# Structured extraction (ContentAnalyzer, RAPTOR, QueryAnalyzer) — fast, no-think
# Leave empty to fall back to LLM_MODEL
INSTRUCT_LLM_MODEL=qwen2.5:7b

# =============================================================================
# Dense Embeddings  — HuggingFace / sentence-transformers (local inference)
# =============================================================================
# Recommended cpu: BAAI/bge-m3 (multilingual, 1024 dim, state of the art)
# Recommended gpu: Qwen/Qwen3-Embedding:4b (multilingual, 2048 dim, state of the art)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu

# =============================================================================
# Sparse Embeddings  — SPLADE via FastEmbed (local inference)
# =============================================================================
# Recommended: Qdrant/bm42-all-minilm-l6-v2-attentions (multilingual, lighter)
SPARSE_EMBEDDING_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions
SPARSE_EMBEDDING_DEVICE=cpu

# =============================================================================
# Content Analyzer  — one LLM call per chunk during indexing
# Uses LLM_MODEL. Adjust ANALYZER_MAX_CONCURRENCY for indexing throughput.
# =============================================================================
ANALYZER_MAX_CONCURRENCY=8
ANALYZER_MAX_CHARS=4000

# =============================================================================
# Classification Taxonomy  (comma-separated labels for ContentAnalyzer)
# =============================================================================
CLASSIFICATION_TAXONOMY=financial,legal,technical,scientific,hr,marketing,contract,report,manual,correspondence,general

# =============================================================================
# Contextual Chunking  (Anthropic Contextual Retrieval)
# =============================================================================
CHILD_CHUNK_SIZE=200          # words per child chunk
CHILD_CHUNK_OVERLAP=20        # word overlap between child chunks
PARENT_ENABLED=true           # swap child → full section for LLM answer context
DOC_BEGINNING_CHARS=1500      # chars of document start sent to context-prefix LLM

# =============================================================================
# RAPTOR  — multi-level summary chunks added during indexing
# =============================================================================
# Generates section-level (raptor_section) and document-level (raptor_doc)
# summary chunks. Enables high-level retrieval for overview questions.
# NOTE: Doubles approximate Qdrant write volume. Re-index after enabling.
RAPTOR_ENABLED=true

# =============================================================================
# Retrieval  — candidate pool
# =============================================================================
DENSE_RETRIEVER_TOP_K=30
SPARSE_RETRIEVER_TOP_K=30

# =============================================================================
# HyDE  — Hypothetical Document Embedding (pre-retrieval)
# =============================================================================
# The LLM generates a hypothetical ideal answer; its embedding is used for
# dense retrieval instead of the raw query vector.
# Sparse retrieval and the reranker always use the original query.
# Uses LLM_MODEL for hypothesis generation.
HYDE_ENABLED=true

# =============================================================================
# Reranker  — HuggingFace cross-encoder (local inference)
# =============================================================================
# Recommended: BAAI/bge-reranker-v2-m3 (multilingual, state of the art)
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=15
RERANKER_DEVICE=cpu

# =============================================================================
# ColBERT  — late-interaction second pass after cross-encoder
# =============================================================================
# Re-scores the top-K candidates using token-level late interaction.
# Requires pylate + ~500 MB model download. Does NOT require index changes.
COLBERT_ENABLED=true
COLBERT_MODEL=colbert-ir/colbertv2.0
COLBERT_TOP_K=5
COLBERT_DEVICE=cpu

# =============================================================================
# CRAG  — Corrective RAG (re-retrieval on low confidence)
# =============================================================================
# If the top score after reranking is below the threshold, the query is
# reformulated and retrieval is retried (up to CRAG_MAX_RETRIES times).
# low_confidence=true is set in the response if threshold is not met.
CRAG_ENABLED=true
CRAG_SCORE_THRESHOLD=0.35
CRAG_MAX_RETRIES=2

# =============================================================================
# Generation  — final context window for the LLM
# =============================================================================
FINAL_TOP_K=5

# =============================================================================
# RAGAS  — Retrieval Augmented Generation Assessment
# =============================================================================
# Enables POST /evaluation/run for measuring retrieval quality
# (faithfulness, answer_relevancy, context_precision).
RAGAS_ENABLED=true

# =============================================================================
# Application
# =============================================================================
TASK_STORE_SIZE=200 # max indexing tasks kept in memory (FIFO)
INDEXING_MAX_CONCURRENT=3
APP_HOST=0.0.0.0
APP_PORT=8000
