# =============================================================================
# Qdrant Vector Database
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=qwepoi123098

# =============================================================================
# MinIO  — Object storage for original uploaded documents
# =============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false          # true for HTTPS / production
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# =============================================================================
# Docling Service  (document extraction: PDF, DOCX, PPTX, XLSX, …)
# =============================================================================
DOCLING_URL=http://localhost:5001/ui
DOCLING_PORT=5001
DOCLING_MAX_WORKERS=4

# =============================================================================
# Dense Embeddings  — HuggingFace / sentence-transformers (local inference)
# =============================================================================
# Recommended: BAAI/bge-m3           (multilingual, 1024 dim, state of the art)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
# Device for embedders + reranker: "cpu" | "cuda" | "cuda:0" | "mps"
# Use "cpu" when a large LLM (Ollama) already occupies GPU VRAM.
EMBEDDING_DEVICE=cpu

# =============================================================================
# Sparse Embeddings  — SPLADE via FastEmbed (local inference, no API needed)
# =============================================================================
# Recommended: Qdrant/bm42-all-minilm-l6-v2-attentions  (multilingual, lighter)
SPARSE_EMBEDDING_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions
# Device for sparse embedder (ONNX): "cpu" | "cuda"
# Independent from EMBEDDING_DEVICE — sparse runs on CPU by default even if dense uses GPU.
SPARSE_EMBEDDING_DEVICE=cpu

# =============================================================================
# Reranker  — HuggingFace cross-encoder (local inference)
# =============================================================================
# Recommended: BAAI/bge-reranker-v2-m3        (multilingual, state of the art)
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=10
# Device for reranker: "cpu" | "cuda" | "cuda:0" | "mps"
RERANKER_DEVICE=cpu

# =============================================================================
# LLM — OpenAI-compatible endpoint
# =============================================================================
# Works with: OpenAI compatible
OPENAI_API_KEY=whatever
OPENAI_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3:14b

# =============================================================================
# Content Analyzer LLM (used during indexing — one call per chunk)
# Use a fast/cheap model. Defaults to LLM_MODEL if not set.
# =============================================================================
ANALYZER_LLM_MODEL=qwen3:14b
ANALYZER_MAX_WORKERS=8            # parallel LLM calls during indexing
ANALYZER_MAX_CHARS=4000           # max chunk chars sent to the analyzer LLM

# =============================================================================
# Classification Taxonomy  (comma-separated labels for ContentAnalyzer)
# =============================================================================
CLASSIFICATION_TAXONOMY=financial,legal,technical,scientific,hr,marketing,contract,report,manual,correspondence,general

# =============================================================================
# Contextual Chunking (Anthropic Contextual Retrieval)
# =============================================================================
# Child chunk size (small — for precise retrieval)
CHILD_CHUNK_SIZE=200          # words
CHILD_CHUNK_OVERLAP=20        # words

# Parent window around each child chunk (for LLM answer generation)
# The parent is the full markdown section the child belongs to.
# Set to 0 to disable parent-child (use child content for everything).
PARENT_ENABLED=true

# How many chars of the document beginning to send to the context-prefix LLM
DOC_BEGINNING_CHARS=1500

# =============================================================================
# Retrieval
# =============================================================================
DENSE_RETRIEVER_TOP_K=30
SPARSE_RETRIEVER_TOP_K=30
FINAL_TOP_K=5

# =============================================================================
# HyDE — Hypothetical Document Embedding
# =============================================================================
# When enabled, the LLM generates a "hypothetical ideal answer" before dense
# retrieval. The hypothetical text is embedded instead of the raw query,
# shifting the query vector closer to the document manifold.
# Sparse retrieval and the reranker always use the original query.
HYDE_ENABLED=true

# =============================================================================
# RAPTOR — Recursive Abstractive Processing for Tree-Organized Retrieval
# =============================================================================
# When enabled, the indexing pipeline generates additional summary chunks
# at section level (chunk_type=raptor_section) and document level
# (chunk_type=raptor_doc). These are embedded and stored alongside normal
# chunks, enabling high-level retrieval for summary/overview questions.
# NOTE: Doubles approximate Qdrant write volume. Re-index after enabling.
RAPTOR_ENABLED=true

# =============================================================================
# CRAG — Corrective RAG
# =============================================================================
# When enabled, retrieval quality is checked after the reranker.
# If the top document score is below the threshold, the query is reformulated
# and retrieval is retried (up to CRAG_MAX_RETRIES times).
# low_confidence=true is set in the response if threshold is not met.
CRAG_ENABLED=true
CRAG_SCORE_THRESHOLD=0.3
CRAG_MAX_RETRIES=2

# =============================================================================
# ColBERT — Late Interaction Reranker (second pass after cross-encoder)
# =============================================================================
# When enabled, ColBERT re-scores the top-K candidates from the cross-encoder
# using token-level late interaction. Requires pylate + ~500 MB model download.
# Does NOT require index changes.
COLBERT_ENABLED=true
COLBERT_MODEL=colbert-ir/colbertv2.0
COLBERT_TOP_K=5
# Device for ColBERT: "cpu" | "cuda" | "cuda:0"
COLBERT_DEVICE=cpu

# =============================================================================
# RAGAS — Retrieval Augmented Generation Assessment
# =============================================================================
# When enabled, POST /evaluation/run is available for measuring retrieval
# quality (faithfulness, answer_relevancy, context_precision).
RAGAS_ENABLED=false

# =============================================================================
# Application Settings
# =============================================================================
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# =============================================================================
# Task Store
# =============================================================================
# Max number of indexing tasks kept in memory (FIFO — oldest evicted first).
TASK_STORE_SIZE=200
INDEXING_MAX_CONCURRENT=3
