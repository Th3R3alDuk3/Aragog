#-----------------------------------------------------
# Model Caches
#-----------------------------------------------------

HF_HUB_OFFLINE=1
HF_HOME=./data/huggingface
FASTEMBED_CACHE_PATH=./data/fastembed

#-----------------------------------------------------
# Server
#-----------------------------------------------------

HOST=0.0.0.0
PORT=8000

#-----------------------------------------------------
# Auth (OpenWebUI JWT)
#-----------------------------------------------------

JWT_SECRET=changeme
JWT_ALGORITHM=HS256

#-----------------------------------------------------
# S3 Storage
#-----------------------------------------------------

MINIO_ENDPOINT=localhost:9000
MINIO_USER=minio
MINIO_PASSWORD=qwepoi123098
MINIO_BUCKET=default
MINIO_URL_EXPIRE=3600

#-----------------------------------------------------
# Document Store
#-----------------------------------------------------

QDRANT_URL=http://localhost:6333
QDRANT_TOKEN=qwepoi123098
QDRANT_EMBEDDING_DIM=1024

QDRANT_COLLECTION=aragog

#-----------------------------------------------------
# Converter
#-----------------------------------------------------

DOCLING_URL=http://localhost:5001
DOCLING_TIMEOUT=600

#-----------------------------------------------------
# Document Chunker
#-----------------------------------------------------

CHUNKER_TOKENIZER=BAAI/bge-m3
CHUNKER_MAX_TOKENS=1000

#-----------------------------------------------------
# Enricher
#-----------------------------------------------------

ENRICHER_MAX_WORKERS=3

OPENAI_URL=http://localhost:11434/v1
OPENAI_TOKEN=whatever
OPENAI_MODEL=gemma4:e4b
OPENAI_TIMEOUT=300

#-----------------------------------------------------
# Embedders (Dense + Sparse)
#-----------------------------------------------------

DENSE_EMBEDDING_MODEL=bge-m3:567m
DENSE_EMBEDDING_URL=http://localhost:11434/v1
DENSE_EMBEDDING_TOKEN=whatever

SPARSE_EMBEDDING_MODEL=Qdrant/bm25
SPARSE_EMBEDDING_LANGUAGE=german
SPARSE_EMBEDDING_DEVICE=cpu

EMBEDDED_META_FIELDS=context,keywords,headings,hypothetical_questions

#-----------------------------------------------------
# Reranker
#-----------------------------------------------------

RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_URL=http://localhost:8001/v1
RERANKER_TOKEN=whatever
